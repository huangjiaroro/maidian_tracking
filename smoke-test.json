{
  "version": 1,
  "commands": [
    {
      "args": ["--json", "ping"],
      "expect_exit_code": 0,
      "expect_stdout_contains": ["\"status\": \"ok\"", "\"entrypoint\": \"tracking-query\""]
    },
    {
      "args": ["--json", "config", "show"],
      "expect_exit_code": 0,
      "expect_stdout_contains": ["\"skillhub_env\":", "\"base_url\":"]
    },
    {
      "args": [
        "--json",
        "data",
        "config"
      ],
      "expect_exit_code": 0,
      "expect_stdout_contains": [
        "\"easy_fetch_base_url\":",
        "\"skillhub_env\":",
        "\"timeout\": 300"
      ]
    }
  ]
}
